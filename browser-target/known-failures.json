{
  "$schema-comment": "known-failure manifest — each entry documents an accepted-failing test with a reason and a categorization. The corpus runner classifies real fails against this manifest: matching entry → KNOWN-FAIL; missing entry → FAIL (real regression); entry exists but test now passes → UNEXPECTED-PASS (prompts cleanup); entry exists but test fails differently → KNOWN-FAIL-CHANGED (diagnostic alert).",

  "$category-refs": {
    "deferred-fs": "fs writable adapter deferred for external integration — see CLAUDE.md scope decision",
    "deferred-net": "net.createServer / TCP sockets deferred for external integration",
    "deferred-child-process": "child_process.spawn JSPI fix is a multi-week architectural project",
    "deferred-vm-cross-realm": "real cross-realm vm needs iframe-RPC or ShadowRealm; same-realm preset is best-effort fallback",
    "inspector-not-supported": "V8 inspector backend not exposed to browser page JS; see NOTES.md inspector-not-supported",
    "v8-natives": "tests using %PrepareFunctionForOptimization etc require --allow-natives-syntax in V8; not enabled in browser builds",
    "asynclocalstorage-promise-hooks": "AsyncLocalStorage promise-hook integration unsupported (universal browser-Node-runtime gap)",
    "no-marker-bootstrap": "test fails before driver emits PASS/FAIL marker; common.js loading issue likely tied to specific binding"
  },

