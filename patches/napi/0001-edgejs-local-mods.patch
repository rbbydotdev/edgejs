@@ -0,0 +1,151 @@
+// JSONL trace layer.  Captures every tracing span (wasmer-wasix already
+// instruments each syscall with `#[instrument(level = "trace")]`) and
+// writes one JSON line per span close, including all recorded fields.
+//
+// Output schema matches the browser harness so a simple `diff -u` over the
+// two files highlights syscall divergence.  See
+// `browser-target/src/trace.ts` for the matching shape on the JS side.
+
+use std::collections::BTreeMap;
+use std::fs::File;
+use std::io::{BufWriter, Write};
+use std::path::Path;
+use std::sync::Mutex;
+use std::time::Instant;
+
+use tracing::field::{Field, Visit};
+use tracing::span::{Attributes, Id, Record};
+use tracing::Subscriber;
+use tracing_subscriber::Layer;
+use tracing_subscriber::layer::Context;
+use tracing_subscriber::registry::LookupSpan;
+
+#[derive(Default)]
+struct FieldVisitor {
+    values: BTreeMap<String, serde_json::Value>,
+}
+
+impl Visit for FieldVisitor {
+    fn record_debug(&mut self, field: &Field, value: &dyn std::fmt::Debug) {
+        self.values
+            .insert(field.name().to_string(), serde_json::Value::String(format!("{:?}", value)));
+    }
+    fn record_str(&mut self, field: &Field, value: &str) {
+        self.values
+            .insert(field.name().to_string(), serde_json::Value::String(value.to_string()));
+    }
+    fn record_i64(&mut self, field: &Field, value: i64) {
+        self.values
+            .insert(field.name().to_string(), serde_json::Value::Number(value.into()));
+    }
+    fn record_u64(&mut self, field: &Field, value: u64) {
+        self.values
+            .insert(field.name().to_string(), serde_json::Value::Number(value.into()));
+    }
+    fn record_bool(&mut self, field: &Field, value: bool) {
+        self.values
+            .insert(field.name().to_string(), serde_json::Value::Bool(value));
+    }
+}
+
+/// A `tracing` Layer that emits one JSONL record per closed span.  Only
+/// captures spans whose target starts with the configured prefixes (so we
+/// don't drown in unrelated subsystems).
+pub struct JsonlTraceLayer {
+    writer: Mutex<BufWriter<File>>,
+    start: Instant,
+    target_prefixes: Vec<&'static str>,
+}
+
+impl JsonlTraceLayer {
+    pub fn new<P: AsRef<Path>>(
+        path: P,
+        target_prefixes: Vec<&'static str>,
+    ) -> std::io::Result<Self> {
+        let file = File::create(path)?;
+        Ok(Self {
+            writer: Mutex::new(BufWriter::new(file)),
+            start: Instant::now(),
+            target_prefixes,
+        })
+    }
+
+    fn matches_target(&self, target: &str) -> bool {
+        self.target_prefixes.is_empty()
+            || self.target_prefixes.iter().any(|p| target.starts_with(p))
+    }
+}
+
+impl<S> Layer<S> for JsonlTraceLayer
+where
+    S: Subscriber + for<'lookup> LookupSpan<'lookup>,
+{
+    fn on_new_span(&self, attrs: &Attributes<'_>, id: &Id, ctx: Context<'_, S>) {
+        let span = match ctx.span(id) {
+            Some(s) => s,
+            None => return,
+        };
+        if !self.matches_target(span.metadata().target()) {
+            return;
+        }
+        let mut visitor = FieldVisitor::default();
+        attrs.record(&mut visitor);
+        span.extensions_mut().insert(visitor);
+    }
+
+    fn on_record(&self, id: &Id, values: &Record<'_>, ctx: Context<'_, S>) {
+        let span = match ctx.span(id) {
+            Some(s) => s,
+            None => return,
+        };
+        if !self.matches_target(span.metadata().target()) {
+            return;
+        }
+        let mut exts = span.extensions_mut();
+        if let Some(v) = exts.get_mut::<FieldVisitor>() {
+            values.record(v);
+        }
+    }
+
+    fn on_close(&self, id: Id, ctx: Context<'_, S>) {
+        let span = match ctx.span(&id) {
+            Some(s) => s,
+            None => return,
+        };
+        let metadata = span.metadata();
+        if !self.matches_target(metadata.target()) {
+            return;
+        }
+        let exts = span.extensions();
+        let visitor = match exts.get::<FieldVisitor>() {
+            Some(v) => v,
+            None => return,
+        };
+        let elapsed = self.start.elapsed();
+        let target = metadata.target();
+        // Normalize target to a short category so browser ↔ native diffs
+        // can match on the same identifiers.  Mirrors `categorize` in
+        // browser-target/src/trace.ts.
+        let category = if target.starts_with("wasmer_wasix::syscalls::wasi::") {
+            "wasi"
+        } else if target.starts_with("wasmer_wasix::syscalls::wasix::") {
+            "wasix"
+        } else if target.starts_with("wasmer_wasix::syscalls") {
+            "wasix"
+        } else {
+            "internal"
+        };
+        let record = serde_json::json!({
+            "t_ms": elapsed.as_secs_f64() * 1000.0,
+            "category": category,
+            "name": metadata.name(),
+            "target": target,
+            "fields": visitor.values,
+        });
+        if let Ok(mut w) = self.writer.lock() {
+            let _ = writeln!(*w, "{}", record);
+            // Flush eagerly — if the wasm crashes we want the last call on disk.
+            let _ = w.flush();
+        }
+    }
+}
