+// ---- Stubs for symbols added downstream in newer wasm releases. ----
+// These must exist so wasmer can satisfy all imports during instantiation.
+// Returning 1 surfaces any actual call as a napi_status error.
+
+// CJS loader variant of contextify_compile_function.
+//
+// Wasm signature (6 args): (napi_env, code, filename, is_sea_main, should_detect_module, result_ptr).
+// Node expects an *object* in `result_ptr` with at least a `function` field; the
+// function itself must be CJS-wrapped, i.e. take (exports, require, module,
+// __filename, __dirname) as parameters so the wrapper code can bind them.
+//
+// We synthesize this by:
+//   1. Building a napi array ["exports", "require", "module", "__filename", "__dirname"]
+//   2. Calling the standard contextify_compile_function with that array as `params`
+//   3. Wrapping the resulting function handle in a fresh object with `function` set
+//
+// `sourceMapURL`/`cachedData`/`cachedDataRejected` are omitted; Node reads them
+// with `?.` so missing fields are tolerated.  When we want true cached-data
+// support we'd thread the C++-side bridge through, but this is enough for
+// boot-time CJS execution and is the entire point of the baseline run.
+fn guest_stub_unofficial_napi_contextify_compile_function_for_cjs_loader(
+    mut env: FunctionEnvMut<NapiEnv>,
+    napi_env: i32,
+    code: i32,
+    filename: i32,
+    _is_sea_main: i32,
+    _should_detect_module: i32,
+    result_ptr: i32,
+) -> i32 {
+    const CJS_PARAMS: [&str; 5] = ["exports", "require", "module", "__filename", "__dirname"];
+    let snapi = snapi_env(&env, napi_env);
+
+    // Build napi string handles for the 5 wrapper-param names.
+    let mut param_ids = [0u32; 5];
+    for (i, name) in CJS_PARAMS.iter().enumerate() {
+        let cs = CString::new(*name).unwrap();
+        let status = unsafe {
+            snapi_bridge_create_string_utf8(snapi, cs.as_ptr(), name.len() as u32, &mut param_ids[i])
+        };
+        if status != 0 {
+            return status;
+        }
+    }
+
+    // Wrap them in an array (the `params` argument).
+    let mut params_array_id = 0u32;
+    if unsafe { snapi_bridge_create_array(snapi, &mut params_array_id) } != 0 {
+        return 1;
+    }
+    for (i, pid) in param_ids.iter().enumerate() {
+        if unsafe { snapi_bridge_set_element(snapi, params_array_id, i as u32, *pid) } != 0 {
+            return 1;
+        }
+    }
+
+    // Delegate to the regular contextify_compile_function.  Its result_out
+    // is *already* the `{ function, sourceURL, sourceMapURL, ... }` shape
+    // Node's wrapSafe expects (see napi/v8/src/unofficial_napi_contextify.cc),
+    // so we just write that handle straight into the guest's result slot.
+    let mut wrapper_object_id = 0u32;
+    let status = unsafe {
+        snapi_bridge_unofficial_contextify_compile_function(
+            snapi,
+            if code > 0 { code as u32 } else { 0 },
+            if filename > 0 { filename as u32 } else { 0 },
+            0, 0, 0, 0, 0, 0,
+            params_array_id,
+            0,
+            &mut wrapper_object_id,
+        )
+    };
+    if status != 0 {
+        return status;
+    }
+    if result_ptr > 0 {
+        write_guest_u32(&mut env, result_ptr as u32, wrapper_object_id);
+    }
+    0
+}
