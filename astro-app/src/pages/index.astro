---
export const prerender = false;

const generatedAt = new Date();
const requestUrl = new URL(Astro.request.url);
const headers = Array.from(Astro.request.headers.entries())
	.slice(0, 6)
	.map(([name, value]) => ({ name, value }));
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>EdgeJS Astro SSR</title>
	</head>
	<body>
		<main>
			<p class="eyebrow">Astro rendered on EdgeJS</p>
			<h1>Server-generated Astro sample</h1>
			<p>
				This page is rendered per request by Astro, not emitted as a static site.
			</p>

			<section class="card">
				<h2>Request details</h2>
				<dl>
					<div>
						<dt>Generated at</dt>
						<dd>{generatedAt.toISOString()}</dd>
					</div>
					<div>
						<dt>Path</dt>
						<dd>{requestUrl.pathname}</dd>
					</div>
					<div>
						<dt>Runtime</dt>
						<dd>{Astro.generator}</dd>
					</div>
				</dl>
			</section>

			<section class="card">
				<h2>Sample headers</h2>
				<ul>
					{headers.map((header) => <li><strong>{header.name}</strong>: {header.value}</li>)}
				</ul>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		color: #f7f7fb;
		background: #111827;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background:
			radial-gradient(circle at top left, rgba(125, 211, 252, 0.2), transparent 36rem),
			#111827;
	}

	main {
		box-sizing: border-box;
		margin: 0 auto;
		max-width: 56rem;
		padding: 5rem 1.5rem;
	}

	h1 {
		font-size: clamp(2.5rem, 8vw, 5rem);
		line-height: 0.95;
		margin: 0 0 1rem;
	}

	h2 {
		margin-top: 0;
	}

	.eyebrow {
		color: #67e8f9;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.card {
		background: rgba(17, 24, 39, 0.72);
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 1rem;
		box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.25);
		margin-top: 1.5rem;
		padding: 1.5rem;
	}

	dl {
		display: grid;
		gap: 1rem;
		margin: 0;
	}

	dt {
		color: #9ca3af;
		font-size: 0.875rem;
	}

	dd {
		margin: 0.25rem 0 0;
		overflow-wrap: anywhere;
	}

	ul {
		margin-bottom: 0;
		padding-left: 1.25rem;
	}
</style>
